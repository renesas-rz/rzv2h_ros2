 build/conf/local.conf |   2 +
 build/conf/ros2.inc   | 184 ++++++++++++++++++++++++++++++++++++++++++
 2 files changed, 186 insertions(+)
 create mode 100644 build/conf/ros2.inc

diff --git a/build/conf/local.conf b/build/conf/local.conf
index 89d0b246..72c8bdf7 100644
--- a/build/conf/local.conf
+++ b/build/conf/local.conf
@@ -323,3 +323,5 @@ IMAGE_INSTALL:append = " e2fsprogs-mke2fs"
 IMAGE_INSTALL:append = " tesseract tesseract-lang "
 
 CORE_IMAGE_EXTRA_INSTALL += "libgomp libgomp-dev libgomp-staticdev"
+
+include conf/ros2.inc
\ No newline at end of file
diff --git a/build/conf/ros2.inc b/build/conf/ros2.inc
new file mode 100644
index 00000000..72d76b6d
--- /dev/null
+++ b/build/conf/ros2.inc
@@ -0,0 +1,184 @@
+# ros2 base
+IMAGE_INSTALL:append = " ros-core"
+IMAGE_INSTALL:append = " demo-nodes-cpp"
+IMAGE_INSTALL:append = " demo-nodes-py"
+
+
+# V4L2
+IMAGE_INSTALL:append = " v4l-utils"
+IMAGE_INSTALL:append = " v4l2-camera"
+
+
+# realsense2
+SKIP_RECIPE[librealsense2] = ""
+SKIP_RECIPE[realsense2-camera] = ""
+IMAGE_INSTALL:append = " librealsense2"
+IMAGE_INSTALL:append = " realsense2-camera"
+IMAGE_INSTALL:append = " realsense2-camera-msgs"
+# image-transport-plugins
+IMAGE_INSTALL:append = " image-transport-plugins"
+
+
+# navigation2
+SKIP_RECIPE[navigation2] = ""
+SKIP_RECIPE[nav2-bringup] = ""
+IMAGE_INSTALL:append = " navigation2 nav2-bringup"
+## X11 not support...
+RDEPENDS:${PN}:remove = " nav2-rviz-plugins"
+# OPEN-MP not support...
+RDEPENDS:${PN}:remove = " nav2-smac-planner"
+RDEPENDS:${PN}:remove = " nav2-mppi-controller"
+
+
+# cartographer
+IMAGE_INSTALL:append = " cartographer-ros"
+
+
+## for cross-build...
