+# Skip License QA
+INHERIT:remove = "create-spdx"
+WARN_QA:remove = "license-exists"
+
+# For git protocol 
+BB_NO_NETWORK = "0"
+FETCHCOMMAND_git = "git -c core.fsyncObjectFiles=0 clone --bare --mirror https://github.com/${UPSTREAM_CHECK_GIT_REPO} ${DL_DIR}/git2/github.com.${UPSTREAM_CHECK_GIT_REPO}"
+
+# Cross-build for demos
+TOOLCHAIN_HOST_TASK:append = " nativesdk-python3-numpy nativesdk-python3-setuptools"
+
+INHERIT += "rm_work"
