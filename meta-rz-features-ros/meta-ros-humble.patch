+# Library competition issue for librealsense2
+PREFERRED_PROVIDER_virtual/libgl = "mali-library"
+PREFERRED_PROVIDER_virtual/egl = "mali-library"
+PREFERRED_PROVIDER_virtual/libgles2 = "mali-library"
